# ------------------------------------
# LabWC Theme: Gruvbox Dark
# ------------------------------------

# general
border.width: 2

window.titlebar.padding.width: 4
window.titlebar.padding.height: 2

# --- WINDOW DECORATIONS ---

# window border
# Active window gets the bright Aqua accent
window.active.border.color: #8ec07c
# Inactive window gets a subtle, dark gray border
window.inactive.border.color: #3c3836

# ToggleKeybinds status indicator (e.g., for resize mode)
# Gruvbox Red for high visibility
window.active.indicator.toggled-keybind.color: #fb4934

# window titlebar background
# Active titlebar: Gruvbox BG3 (slightly lighter)
window.active.title.bg.color: #3c3836
# Inactive titlebar: Main background (BG0_H)
window.inactive.title.bg.color: #1d2021
window.*.title.bg: Solid

# window titlebar text
# Bright cream foreground for readability
window.active.label.text.color: #ebdbb2
# Muted gray for inactive windows
window.inactive.label.text.color: #928374
window.label.text.justify: center

# window button width and spacing
window.button.width: 24
window.button.height: 24
window.button.spacing: 4

# window buttons (close, max, min icons)
window.active.button.unpressed.image.color: #ebdbb2
window.inactive.button.unpressed.image.color: #7c6f64

# Custom button colors on hover (Gruvbox signaling colors)
window.active.button.hover.bg.color: #504945
window.active.button.close.hover.bg.color: #fb4934
window.active.button.max.hover.bg.color: #b8bb26
window.active.button.iconify.hover.bg.color: #fabd2f

# window drop-shadows (subtle warm-tinted shadow)
window.active.shadow.size: 20
window.inactive.shadow.size: 10
window.active.shadow.color: #00000095
window.inactive.shadow.color: #00000070


# --- MENUS (Right-click menu, etc.) ---

menu.border.width: 1
menu.border.color: #8ec07c
# Main background
menu.items.bg.color: #282828
# Main foreground text
menu.items.text.color: #ebdbb2
# Selection color (BG4/Gray)
menu.items.active.bg.color: #504945
menu.items.active.text.color: #fbf1c7
menu.items.padding.x: 10
menu.items.padding.y: 6
menu.separator.width: 1
menu.separator.padding.width: 4
menu.separator.padding.height: 4
# Subtle separator line
menu.separator.color: #504945
# Menu title gets the Aqua accent
menu.title.bg.color: #8ec07c
# Dark background text for contrast
menu.title.text.color: #1d2021
menu.title.text.justify: Center


# --- ON SCREEN DISPLAY (OSD - e.g., Alt+Tab Window Switcher) ---

osd.bg.color: #282828
osd.border.color: #8ec07c
osd.border.width: 2
osd.label.text.color: #ebdbb2

osd.window-switcher.width: 50%
osd.window-switcher.padding: 10
osd.window-switcher.item.padding.x: 10
osd.window-switcher.item.padding.y: 10
osd.window-switcher.item.active.border.width: 2
osd.window-switcher.preview.border.width: 1
osd.window-switcher.preview.border.color: #d3869b

# --- SNAPPING OVERLAY (When tiling windows to edges) ---

# Semi-transparent Aqua for snap area
snapping.overlay.region.bg.color: #8ec07c40
snapping.overlay.edge.bg.color: #8ec07c40
snapping.overlay.region.border.width: 2
snapping.overlay.edge.border.width: 2
# Solid Aqua border
snapping.overlay.region.border.color: #8ec07c
snapping.overlay.edge.border.color: #8ec07c
