    match app-id=r#"lutris$"#
    open-on-workspace "’äø"
}
window-rule {
    match app-id=r#"^com\.usebottles\.bottles$"#
    open-on-workspace "’äø"
}

window-rule {
    match app-id=r#"^org\.telegram\.desktop$"#
    open-on-workspace "ŅłŚ"
}


window-rule {
    match app-id=r#"^virt-manager$"#
    open-on-workspace "’äł"
