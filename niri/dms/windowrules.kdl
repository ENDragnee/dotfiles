// Window rules.
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}
window-rule {
    match app-id="vlc"
    open-fullscreen true
}

window-rule {
    match app-id=r#"brave-browser$"#
    open-on-workspace "’Æē" 
    open-maximized true
}
window-rule {
    match app-id=r#"firefox$"#
    open-on-workspace "’ē®" 
    open-maximized true
}
window-rule {
    match app-id=r#"zen$"#
    open-on-workspace "’ē®" 
    open-maximized true
}

window-rule {
    match app-id=r#"^libreoffice-.*$"#
    open-on-workspace "’ü╗"
    open-maximized true
}


window-rule {
    match app-id=r#"steam$"#
    open-on-workspace "’äø"
    open-maximized true
}
