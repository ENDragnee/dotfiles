window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}
window-rule {
    match app-id=r#"zen$"# title="^Picture-in-Picture$"
    open-floating true
}
window-rule {
    match app-id=r#"brave-browser$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
  match app-id=r#"rofi"#
  open-floating true
}
window-rule {
  match app-id=r#"pavucontrol"#
  open-floating true
}
window-rule {
  match app-id=r#"pwvucontrol"#
  open-floating true
}
window-rule {
    match app-id="wine"
    default-floating-position x=0 y=0
}

window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#
    block-out-from "screen-capture"
}

window-rule {
    open-focused true
    opacity 1.0
}
