window-rule {
    match app-id=r#"code"#
    open-on-workspace "’Ŗ¢"
}
window-rule {
    match app-id=r#"jetbrains-idea-ce"#
    open-on-workspace "’Ŗ¢"
}


window-rule {
    match app-id=r#"^com\.github\.taiko2k\.tauonmb$"#
    open-on-workspace "’å╝"
}
window-rule {
    match app-id=r#"Spotify"#
